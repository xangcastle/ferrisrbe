{
  "$schema": "https://railway.app/railway.schema.json",
  "name": "FerrisRBE - Full Remote Build Execution",
  "description": "High-performance RBE server for Bazel with Remote Cache and Remote Execution. Includes native CAS and ActionCache storage, RBE server, and workers.",
  "icon": "https://bazel.build/images/bazel-icon.svg",
  "author": "xangcastle",
  "services": {
    "rbe-cache": {
      "image": "xangcastle/ferris-cache:latest",
      "variables": {
        "RUST_LOG": {
          "default": "info",
          "description": "Log level"
        },
        "RBE_CACHE_PORT": {
          "default": "9094",
          "description": "gRPC port for CAS and ActionCache"
        },
        "RBE_CACHE_HTTP_PORT": {
          "default": "8080",
          "description": "HTTP port for status endpoint"
        },
        "RBE_CACHE_DIR": {
          "default": "/data",
          "description": "Directory for CAS storage"
        },
        "RBE_CACHE_MAX_SIZE_GB": {
          "default": "5",
          "description": "Maximum CAS cache size in GB"
        },
        "RBE_CACHE_AC_MAX_SIZE_GB": {
          "default": "1",
          "description": "Maximum Action Cache size in GB"
        }
      },
      "volumes": ["/data"]
    },
    "ferrisrbe-server": {
      "image": "xangcastle/ferris-server:latest",
      "variables": {
        "RBE_PORT": {
          "default": "${PORT}",
          "description": "Server port (auto-assigned by Railway)"
        },
        "RBE_BIND_ADDRESS": {
          "default": "0.0.0.0",
          "description": "Bind address for server"
        },
        "RUST_LOG": {
          "default": "info",
          "description": "Log level (trace/debug/info/warn/error)"
        },
        "CAS_ENDPOINT": {
          "default": "rbe-cache:9094",
          "description": "Native cache server (rbe-cache) endpoint"
        },
        "RBE_L1_CACHE_CAPACITY": {
          "default": "100000",
          "description": "L1 action cache capacity"
        },
        "RBE_TLS_CERT": {
          "default": "",
          "description": "TLS certificate (PEM) - leave empty for plaintext"
        },
        "RBE_TLS_KEY": {
          "default": "",
          "description": "TLS private key (PEM) - leave empty for plaintext"
        }
      },
      "healthcheck": {
        "path": "/health",
        "timeout": 100
      },
      "dependsOn": ["rbe-cache"]
    },
    "ferrisrbe-worker": {
      "image": "xangcastle/ferris-worker:latest",
      "variables": {
        "WORKER_ID": {
          "default": "railway-worker",
          "description": "Unique worker identifier"
        },
        "SERVER_ENDPOINT": {
          "default": "http://ferrisrbe-server:9092",
          "description": "RBE server endpoint"
        },
        "CAS_ENDPOINT": {
          "default": "http://rbe-cache:9094",
          "description": "Native cache server endpoint"
        },
        "RUST_LOG": {
          "default": "info",
          "description": "Log level"
        },
        "MAX_CONCURRENT": {
          "default": "4",
          "description": "Maximum concurrent executions per worker"
        },
        "WORKER_TYPE": {
          "default": "default",
          "description": "Worker type (default, highcpu, gpu)"
        },
        "WORKER_LABELS": {
          "default": "os=linux,arch=amd64",
          "description": "Worker labels for action matching"
        }
      },
      "dependsOn": ["ferrisrbe-server"],
      "restart": {
        "policy": "ON_FAILURE",
        "maxRetries": 10
      }
    }
  }
}
