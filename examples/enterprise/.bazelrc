startup --host_jvm_args=-Xmx6g
startup --host_jvm_args=-Xms2g
startup --host_jvm_args=-XX:+UseG1GC
startup --host_jvm_args=-XX:MaxGCPauseMillis=200

build --symlink_prefix=/

build:remote-cache --remote_cache=grpc://localhost:9094
build:remote-cache --remote_upload_local_results=true
build:remote-cache --remote_timeout=600

build:remote-exec --config=remote-cache
build:remote-exec --remote_executor=grpc://localhost:9092
build:remote-exec --extra_execution_platforms=//toolchains:linux_arm64
build:remote-exec --platforms=//toolchains:linux_arm64
build:remote-exec --extra_toolchains=//toolchains:gcc_linux_arm64_toolchain
build:remote-exec --repo_env=CC=gcc
build:remote-exec --repo_env=CXX=g++
build:remote-exec --features=-module_maps
build:remote-exec --jobs=50
