# Bazel Buildfarm Worker Configuration (SHARD mode)
# Minimal configuration for benchmarking.
#
# Schema follows the modern buildfarm YAML config; workers register themselves
# in the Redis backplane under publicName, which must be resolvable by the
# server inside the compose network.
backplane:
  redisUri: "redis://buildfarm-redis:6379"
  queues:
    - name: "cpu"
      allowUnmatched: true
      properties:
        - name: "*"
          value: "*"

worker:
  port: 8981
  publicName: "buildfarm-worker:8981"
  root: /tmp/worker
  capabilities:
    cas: true
    execution: true
  storages:
    - type: FILESYSTEM
      path: cache
      maxSizeBytes: 2147483648
  executeStageWidth: 4
  inputFetchStageWidth: 2
  dequeueMatchSettings:
    allowUnmatched: true
  # cgroups are unavailable inside the unprivileged-by-default benchmark
  # containers; the default (true) makes every execution fail.
  sandboxSettings:
    alwaysUseCgroups: false
