# Bazel Buildfarm Server Configuration (SHARD mode)
# Minimal configuration for benchmarking.
#
# Schema follows the modern buildfarm YAML config (the old proto-text format
# previously in this file was silently ignored by bazelbuild/buildfarm:latest,
# which then fell back to defaults and tried to reach Redis on localhost).
backplane:
  redisUri: "redis://buildfarm-redis:6379"
  queues:
    - name: "cpu"
      allowUnmatched: true
      properties:
        - name: "*"
          value: "*"

server:
  instanceType: SHARD
  name: shard
  port: 9092
