        "@crates//:dashmap",
        "@crates//:fastrand",
        "@crates//:futures",
        "@crates//:hex",
        "@crates//:once_cell",
        "@crates//:parking_lot",
        "@crates//:prost",
        "@crates//:prost-types",
        "@crates//:serde",
        "@crates//:serde_bytes",
        "@crates//:serde_json",
        "@crates//:sha2",
        "@crates//:tempfile",
        "@crates//:thiserror",
        "@crates//:tokio",
