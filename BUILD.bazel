    name = "rbe_lib_test",
    crate = ":rbe_lib",
    edition = "2021",
    proc_macro_deps = [
        "@crates//:async-trait",
    ],
    deps = [
        ":build_script",
        "@crates//:ahash",
        "@crates//:anyhow",
        "@crates//:async-stream",
        "@crates//:bytes",
        "@crates//:chrono",
        "@crates//:crossbeam",
        "@crates//:dashmap",
        "@crates//:fastrand",
        "@crates//:futures",
        "@crates//:hex",
        "@crates//:once_cell",
        "@crates//:parking_lot",
        "@crates//:prost",
        "@crates//:prost-types",
        "@crates//:serde",
        "@crates//:serde_bytes",
        "@crates//:serde_json",
        "@crates//:sha2",
        "@crates//:tempfile",
        "@crates//:thiserror",
        "@crates//:tokio",
        "@crates//:tokio-stream",
        "@crates//:tokio-util",
        "@crates//:tonic",
        "@crates//:tracing",
        "@crates//:tracing-subscriber",
        "@crates//:uuid",
    ],
)

# ============================================================================
# Target para compilar todo
# ============================================================================

filegroup(
    name = "all",
    srcs = [
        ":rbe-server",
        ":rbe-worker",
    ],
    visibility = ["//visibility:public"],
)
