    entrypoint = ["/app/worker"],
    env = {
        "RUST_LOG": "info",
        "WORKER_ID": "",
        "SERVER_ENDPOINT": "http://server:9092",
        "CAS_ENDPOINT": "http://cache:9094",
        "WORKER_TYPE": "default",
        "WORKER_LABELS": "os=linux,arch=amd64",
        "MAX_CONCURRENT": "4",
        "WORKDIR": "/workspace",
    },
