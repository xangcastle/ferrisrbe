load("@aspect_bazel_lib//lib:tar.bzl", "tar")
load("@aspect_bazel_lib//lib:transitions.bzl", "platform_transition_filegroup")
load("@rules_oci//oci:defs.bzl", "oci_image", "oci_image_index", "oci_load", "oci_push")

platform_transition_filegroup(
    name = "server.amd64",
    srcs = ["//:server"],
    target_platform = "//platforms:linux_amd64",
)

tar(
    name = "server.amd64.layer",
    srcs = [":server.amd64"],
    mtree = [
        "./app/server type=file content=$(execpath :server.amd64)",
    ],
)

oci_image(
    name = "server.amd64.image",
    base = "@debian_bookworm_slim_linux_amd64",
    entrypoint = ["/app/server"],
    exposed_ports = ["9092"],
    tars = [":server.amd64.layer"],
    visibility = ["//visibility:public"],
)

oci_load(
    name = "server.amd64.image.load",
    image = ":server.amd64.image",
    repo_tags = ["ferrisrbe/server:latest"],
    visibility = ["//visibility:public"],
)

platform_transition_filegroup(
    name = "server.arm64",
    srcs = ["//:server"],
    target_platform = "//platforms:linux_arm64",
)

tar(
    name = "server.arm64.layer",
    srcs = [":server.arm64"],
    mtree = [
        "./app/server type=file content=$(execpath :server.arm64)",
    ],
)

oci_image(
    name = "server.arm64.image",
    base = "@debian_bookworm_slim_linux_arm64_v8",
    entrypoint = ["/app/server"],
    exposed_ports = ["9092"],
    tars = [":server.arm64.layer"],
    visibility = ["//visibility:public"],
)

oci_load(
    name = "server.arm64.image.load",
    image = ":server.arm64.image",
    repo_tags = ["ferrisrbe/server:latest"],
    visibility = ["//visibility:public"],
)

oci_image_index(
    name = "server.image.multiplatform",
    images = [
        ":server.amd64.image",
        ":server.arm64.image",
    ],
    visibility = ["//visibility:public"],
)

oci_push(
    name = "server.image.push",
    image = ":server.image.multiplatform",
    repository = "docker.io/xangcastle/ferris-server",
    visibility = ["//visibility:public"],
)

